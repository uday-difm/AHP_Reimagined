{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "node scripts/generate-routes.js && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "npx prisma generate --schema=prisma/schema.prisma",
    "db:push": "npx prisma db push --schema=prisma/schema.prisma --accept-data-loss",
    "db:seed": "node prisma/seed.js",
    "db:migrate": "npx prisma migrate deploy --schema=prisma/schema.prisma",
    "postinstall": "prisma generate --schema=prisma/schema.prisma"
  },
