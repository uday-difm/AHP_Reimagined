  const [status, setStatus] = useState("DRAFT");
  const [jsonLd, setJsonLd] = useState("");
  const [canonicalUrl, setCanonicalUrl] = useState("");
  const [ogImage, setOgImage] = useState("");
  const [isHardcoded, setIsHardcoded] = useState(false);

