                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      )}

      {/* --- TAB 3: CUSTOM REPORTS GENERATOR --- */}
      {activeTab === "reports" && (
        <div className="space-y-6 animate-in fade-in duration-200">
