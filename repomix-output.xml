  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  subject     String
  body        String   @db.LongText
  listId      String?
  list        SubscriberList? @relation(fields: [listId], references: [id], onDelete: SetNull)
