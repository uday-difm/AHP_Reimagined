                <Scene
                  frontUrl={mag.coverImage}
                  backUrl={mag.backImage || mag.coverImage}
                  spineUrl={mag.spineImage || mag.coverImage}
                />
              </div>

              {/* MagCloud/Link Purchase Buttons */}
