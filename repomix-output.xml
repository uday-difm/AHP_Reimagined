      const data = await res.json();
      if (res.ok && !data.error) {
        setHealthData(data.data || data);
      } else {
        throw new Error(data.error || "Failed to fetch health check details");
      }
    } catch (err) {
      setHealthError(err.message);
    } finally {
      setHealthLoading(false);
    }
  };

