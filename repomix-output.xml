        body: JSON.stringify({
          lazyLoading,
          lazyLoadImages,
          lazyLoadVideos,
          compressImagesOnUpload: compressImages,
          browserCachingDays: cachingDays,
          minifyHtml,
          deferNonEssentialScripts: deferScripts,
