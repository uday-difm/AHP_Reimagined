<file path="prisma/schema.prisma">
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  SUPERADMIN
  ADMIN
  EDITOR
  AUTHOR
  VIEWER
}

enum SiteRole {
  ADMIN
  EDITOR
  AUTHOR
  VIEWER
}

model Site {
  id        String    @id @default(cuid())
  name      String
  domain    String?   @unique @db.VarChar(191)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users SiteUser[]
  pages Page[]

  integrationKey       String?                 @unique @db.VarChar(191)
  frontendProjects     FrontendProject[]
  integrationManifests IntegrationManifest[]
  globalSettings       GlobalSettings[]
  webhookEvents        WebhookEvent[]
  webhookSubscriptions WebhookSubscription[]
  posts                Post[]
  categories           Category[]
  tags                 Tag[]
  services             Service[]
  testimonials         Testimonial[]
  faqs                 Faq[]
  teamMembers          TeamMember[]
  legalPages           LegalPage[]
  redirects            Redirect[]
  visitorLogs          VisitorLog[]
  contactSubmissions   ContactFormSubmission[]
  leads                Lead[]
  apiKeys              ApiKey[]
  media                Media[]
  mediaFolders         MediaFolder[]
  ipBlocks             IpBlock[]
  errorLogs            SystemErrorLog[]
  notificationAlerts   NotificationAlert[]
  contentVersions      ContentVersion[]
  newsletters          Newsletter[]
  subscribers          Subscriber[]
  subscriberLists      SubscriberList[]
  emailTemplates       EmailTemplate[]
  emailCampaigns       EmailCampaign[]
  pushNotifications    PushNotification[]
  cookieConsentLogs    CookieConsentLog[]
  comments             Comment[]
  adZones              AdZone[]

  @@index([isActive])
}

model User {
  id String @id @default(cuid())

  email                String                @unique @db.VarChar(191)
  name                 String?
  bio                  String?
  passwordHash         String
  webhookSubscriptions WebhookSubscription[]
  globalRole           GlobalRole            @default(VIEWER)

  isActive Boolean @default(true)

  twoFAEnabled Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sites SiteUser[]

  auditLogs      AuditLog[]
  loginHistory   LoginHistory[]
  twoFactor      TwoFactor?
  posts          Post[]
  passwordResets PasswordReset[]

  @@index([email])
  @@index([isActive])
}

model SiteUser {
  id String @id @default(cuid())

  siteId String @db.VarChar(50)
  userId String @db.VarChar(50)

  role SiteRole @default(EDITOR)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
  @@index([siteId])
  @@index([userId])
}

model AuditLog {
  id String @id @default(cuid())

  siteId String?
  userId String

  action String

  meta Json?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([siteId])
  @@index([userId])
  @@index([createdAt])
}

model LoginHistory {
  id String @id @default(cuid())

  userId String

  ipAddress String?
  userAgent String?

  success Boolean @default(true)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model TwoFactor {
