// ========== CRM & SUBSCRIBERS ==========
model Subscriber {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  email       String @db.VarChar(50)
  name        String?
  status      String   @default("active") // active, unsubscribed, bounced, spam
