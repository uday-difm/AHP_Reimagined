            {filtered.length} results · Page {page + 1} of {total}
          </span>
          <div className="flex items-center gap-1">
            <button
              disabled={page === 0}
              onClick={() => setPage((p) => p - 1)}
              className="p-1 rounded hover:bg-gray-100 disabled:opacity-40"
