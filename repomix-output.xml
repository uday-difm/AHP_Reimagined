              {selectedLog.stack || "No call stack trace captured."}
            </div>
          </div>
        </div>
      )}
      {activeTab === "webhooks" && (
        <div className="p-6">
          <WebhookManager siteId={siteId} initialWebhooks={initialWebhooks} />
        </div>
      )}
    </div>
  );
}
