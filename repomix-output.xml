<file path="src/app/globals.css">
@import "tailwindcss";

/* ─── Tailwind v4: use class-based dark mode (for next-themes compatibility) ─── */
@variant dark (&:where(.dark, .dark *));

@theme {
  --font-heading: 'Outfit', sans-serif;
  --font-body: 'Inter', sans-serif;
  --font-serif: 'Playfair Display', serif;

  --color-primary: #1a1a2e;
  --color-secondary: #4a4a5a;
  --color-accent: #0f7c85;
  --color-accent-green: #27ae60;
  --color-bg-light: #f8fafc;
  --color-bg-white: #ffffff;
  --color-bg-dark: #121318;
  --color-bg-timeline: #d4e0e6;
  --color-muted: #8e9ca6;
  --color-border: #e2e8f0;

  /* Badge Color Tokens */
  --color-badge-green-bg: #e8f8f0;
  --color-badge-green-text: #27ae60;
  --color-badge-red-bg: #fdecea;
  --color-badge-red-text: #e05248;
  --color-badge-blue-bg: #e8f4ff;
  --color-badge-blue-text: #1fb9fb;
  --color-badge-yellow-bg: #fff8e8;
  --color-badge-yellow-text: #f39c12;
  --color-badge-purple-bg: #f3eeff;
  --color-badge-purple-text: #8e44ad;

  --animate-float-blobs-1: float-blobs 20s infinite alternate ease-in-out;
  --animate-float-blobs-2: float-blobs 28s infinite alternate ease-in-out 2s;
  --animate-float-blobs-3: float-blobs 22s infinite alternate ease-in-out 5s;
  --animate-pulse-slow: pulse-dot 1.8s infinite ease-in-out;
  --animate-marquee: marquee 35s linear infinite;
  --animate-float-phone: float-phone 6s infinite ease-in-out;

  @keyframes float-blobs {
    0% {
      transform: translate(0, 0) scale(1) rotate(0deg);
    }

    33% {
      transform: translate(80px, -50px) scale(1.15) rotate(120deg);
    }

    66% {
      transform: translate(-60px, 40px) scale(0.9) rotate(240deg);
    }

    100% {
      transform: translate(0, 0) scale(1) rotate(360deg);
    }
  }

  @keyframes pulse-dot {
    0% {
      transform: scale(0.8);
      opacity: 0.5;
    }

    50% {
      transform: scale(1.3);
      opacity: 1;
    }

    100% {
      transform: scale(0.8);
      opacity: 0.5;
    }
  }

  @keyframes marquee {
    0% {
      transform: translate3d(0, 0, 0);
    }

    100% {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @keyframes float-phone {
    0% {
      transform: translate3d(0, 0, 0);
    }

    50% {
      transform: translate3d(0, -12px, 0);
    }

    100% {
      transform: translate3d(0, 0, 0);
    }
  }
}

/* Tailwind Base Layer Customizations */
@layer base {
  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    font-family: var(--font-body);
    background-color: var(--color-bg-light);
    color: var(--color-secondary);
    line-height: 1.6;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  .blob {
    will-change: transform;
  }
}

/* ─── Custom Swiper Pagination override ─── */
.swiper-custom-pagination .swiper-pagination-bullet,
.swiper-timeline-pagination .swiper-pagination-bullet,
.timeline-swiper .swiper-pagination-bullet {
  width: 8px;
  height: 8px;
  background: #94a3b8;
  opacity: 0.8;
  border-radius: 50%;
  transition: all 0.3s ease;
  cursor: pointer;
}

.swiper-custom-pagination .swiper-pagination-bullet-active,
.swiper-timeline-pagination .swiper-pagination-bullet-active,
.timeline-swiper .swiper-pagination-bullet-active {
  width: 24px;
  background: #0f7c85;
  border-radius: 4px;
  opacity: 1;
}

/* Custom Tailwind v4 Utilities */
@utility custom-cursor {
  position: fixed;
  top: 0;
  left: 0;
  width: 32px;
  height: 32px;
  border: 1.5px solid var(--color-accent);
  border-radius: 50%;
  pointer-events: none;
  z-index: 99999;
  transform: translate(-50%, -50%);
  transition: transform 0.15s cubic-bezier(0.25, 1, 0.5, 1),
    width 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94),
    height 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94),
    background-color 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  mix-blend-mode: difference;
}

@utility custom-cursor-hover {
  width: 56px !important;
  height: 56px !important;
  background-color: rgba(31, 185, 251, 0.15) !important;
  border-color: var(--color-accent) !important;
}

@utility custom-cursor-nav-hover {
  border-radius: 9999px !important;
  background-color: rgba(15, 124, 133, 0.1) !important;
  border: 1px solid var(--color-accent) !important;
  mix-blend-mode: normal !important;
}

@utility reveal-base {
  opacity: 0;
  transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

@utility reveal-text {
  opacity: 0;
  transform: translateY(60px);
  transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

@utility reveal-slide {
  opacity: 0;
  transform: translateY(40px);
  transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

@utility reveal-scale {
  opacity: 0;
  transform: scale(0.95) translateY(30px);
  transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

@utility reveal-fade {
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

@utility reveal-active {
  opacity: 1 !important;
  transform: none !important;
}

@utility animate-marquee {
  animation: var(--animate-marquee);
}

@utility container {
  margin-left: auto;
  margin-right: auto;
  padding-left: 2.5rem;
  padding-right: 2.5rem;
  width: 100%;
}

@keyframes slide-up {
  from {
    transform: translateY(24px) scale(0.98);
    opacity: 0;
  }

  to {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

@utility animate-slide-up {
  animation: slide-up 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes slide-up {
  from {
    transform: translateY(24px) scale(0.98);
    opacity: 0;
  }

  to {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

@utility animate-slide-up {
  animation: slide-up 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* ─── Scroll Locking for Navigation Overlays ─── */
html.hb-no-scroll {
  overflow-y: scroll !important;
}

body.hb-no-scroll {
  overflow: hidden !important;
  height: 100vh !important;
  touch-action: none;
}

/* ─── 3D Book Effect ─── */
.book-3d-container {
  perspective: 1200px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.book-3d {
  width: 200px;
  height: 270px;
  position: relative;
  transform-style: preserve-3d;
  transform: rotateX(12deg) rotateY(-24deg) rotateZ(-3deg);
  transition: transform 3.5s ease-in-out, box-shadow 3.5s ease-in-out;
  animation: book-idle-rotate 6s infinite ease-in-out;
  box-shadow: -15px 15px 30px rgba(0, 0, 0, 0.2),
    -2px 2px 5px rgba(0, 0, 0, 0.1),
    0 0 1px rgba(0, 0, 0, 0.1);
}

@keyframes book-idle-rotate {
  0% {
    transform: rotateX(12deg) rotateY(-24deg) rotateZ(-3deg) translateY(0);
  }

  50% {
    transform: rotateX(16deg) rotateY(-18deg) rotateZ(-2deg) translateY(-8px);
  }

  100% {
    transform: rotateX(12deg) rotateY(-24deg) rotateZ(-3deg) translateY(0);
  }
}

@media (min-width: 768px) {
  .book-3d {
    width: 240px;
    height: 320px;
  }
}

.book-3d-container:hover .book-3d {
  animation: none;
  transform: rotateX(12deg) rotateY(156deg) rotateZ(3deg) scale(1.03);
  box-shadow: 15px 15px 30px rgba(0, 0, 0, 0.25),
    2px 2px 5px rgba(0, 0, 0, 0.15),
    0 0 1px rgba(0, 0, 0, 0.1);
  transition-delay: 2s
}

/* Front Cover */
.book-3d-cover {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border-radius: 4px 12px 12px 4px;
  transform: translateZ(10px);
  transform-style: preserve-3d;
  z-index: 5;
  box-shadow: inset 4px 0 10px rgba(0, 0, 0, 0.15);
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
  overflow: hidden;
}

/* Page Spines / Thickness (The right edges of the book pages) */
.book-3d-pages {
  position: absolute;
  top: 3px;
  bottom: 3px;
  right: -9px;
  width: 20px;
  background: #fcfbf9;
  transform: rotateY(90deg);
  transform-style: preserve-3d;
  box-shadow: inset 3px 0 10px rgba(0, 0, 0, 0.12);
  border-radius: 0 3px 3px 0;
  background-image: repeating-linear-gradient(0deg,
      #eae8e2 0px,
      #eae8e2 1px,
      #fcfbf9 1px,
      #fcfbf9 4px);
  z-index: 3;
}

/* Top Pages Edge Thickness */
.book-3d-pages-top {
  position: absolute;
  top: -7px;
  left: 3px;
  right: 3px;
  height: 20px;
  background: #faf9f6;
  transform: rotateX(90deg);
  transform-style: preserve-3d;
  box-shadow: inset 0 3px 8px rgba(0, 0, 0, 0.12);
  background-image: repeating-linear-gradient(90deg,
      #eae8e2 0px,
      #eae8e2 1px,
      #faf9f6 1px,
      #faf9f6 4px);
  z-index: 3;
}

/* Bottom Pages Edge Thickness */
.book-3d-pages-bottom {
  position: absolute;
  bottom: -7px;
  left: 3px;
  right: 3px;
  height: 20px;
  background: #faf9f6;
  transform: rotateX(-90deg);
  transform-style: preserve-3d;
  box-shadow: inset 0 -3px 8px rgba(0, 0, 0, 0.12);
  background-image: repeating-linear-gradient(90deg,
      #eae8e2 0px,
      #eae8e2 1px,
      #faf9f6 1px,
      #faf9f6 4px);
  z-index: 3;
}

/* Spine (The left edge thickness of the book) */
.book-3d-spine {
  position: absolute;
  top: 0;
  bottom: 0;
  left: -10px;
  width: 20px;
  background: linear-gradient(to right, #091e1b 0%, #123d37 20%, #1f5e55 50%, #123d37 80%, #091e1b 100%);
  transform: rotateY(-90deg);
  transform-style: preserve-3d;
  z-index: 4;
  border-radius: 4px 0 0 4px;
  box-shadow: inset -1px 0 3px rgba(0, 0, 0, 0.3), inset 1px 0 3px rgba(255, 255, 255, 0.1);
}

/* Back Cover */
.book-3d-back {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  background: #0f7c85;
  /* same as the button brand teal */
  border-radius: 12px 4px 4px 12px;
  transform: rotateY(180deg) translateZ(10px);
  z-index: 1;
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
  box-shadow: 5px 5px 15px rgba(0, 0, 0, 0.3);
  overflow: hidden;
}

/* Front Cover Shine/Crease lines overlay */
.book-3d-cover::after {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  left: 11px;
  width: 1px;
  background: rgba(255, 255, 255, 0.2);
  box-shadow: -1px 0 2px rgba(0, 0, 0, 0.3), 1px 0 2px rgba(255, 255, 255, 0.15);
  z-index: 10;
}

.book-3d-cover::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(115deg,
      rgba(255, 255, 255, 0.15) 0%,
      rgba(255, 255, 255, 0.08) 25%,
      rgba(0, 0, 0, 0) 45%,
      rgba(0, 0, 0, 0.18) 100%);
  z-index: 9;
  pointer-events: none;
  mix-blend-mode: multiply;
}

/* Homepage Magazine Spread Stack */
.spread-stack-container {
  position: relative;
  width: 100%;
  max-width: 480px;
  height: 240px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spread-card {
  position: absolute;
  width: 150px;
  height: 200px;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.12);
  transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

.spread-card-left {
  transform: translate3d(-70px, 5px, 0) rotate(-10deg) scale(0.9);
  z-index: 10;
}

.spread-card-right {
  transform: translate3d(70px, 5px, 0) rotate(10deg) scale(0.9);
  z-index: 10;
}

.spread-card-center {
  transform: translate3d(0, -5px, 0) rotate(0deg) scale(1.03);
  z-index: 20;
}

/* Hover dynamic spread apart states */
.spread-stack-container:hover .spread-card-left {
  transform: translate3d(-130px, -10px, 0) rotate(-18deg) scale(0.95);
  box-shadow: 0 15px 35px rgba(0, 0, 0, 0.18);
}

.spread-stack-container:hover .spread-card-right {
  transform: translate3d(130px, -10px, 0) rotate(18deg) scale(0.95);
  box-shadow: 0 15px 35px rgba(0, 0, 0, 0.18);
}

.spread-stack-container:hover .spread-card-center {
  transform: translate3d(0, -15px, 0) rotate(0deg) scale(1.08);
  box-shadow: 0 20px 45px rgba(0, 0, 0, 0.22);
}

/* ─── Cinematic Page Wipe Transition ─── */
@keyframes slide-in-wipe {
  from {
    transform: translate3d(100%, 0, 0);
  }

  to {
    transform: translate3d(0, 0, 0);
  }
}

@keyframes slide-out-wipe {
  from {
    transform: translate3d(0, 0, 0);
  }

  to {
    transform: translate3d(100%, 0, 0);
  }
}

@utility wipe-enter {
  animation: slide-in-wipe 0.65s cubic-bezier(0.87, 0, 0.13, 1) forwards;
  will-change: transform;
}

@utility wipe-exit {
  animation: slide-out-wipe 0.65s cubic-bezier(0.87, 0, 0.13, 1) forwards;
  will-change: transform;
}

/* ─── Cinematic Page Wipe Transition ─── */
@keyframes slide-in-wipe {
  from {
    transform: translate3d(100%, 0, 0);
  }

  to {
    transform: translate3d(0, 0, 0);
  }
}

@keyframes slide-out-wipe {
  from {
    transform: translate3d(0, 0, 0);
  }

  to {
    transform: translate3d(100%, 0, 0);
  }
}

@utility wipe-enter {
  animation: slide-in-wipe 0.65s cubic-bezier(0.87, 0, 0.13, 1) forwards;
  will-change: transform;
}

@utility wipe-exit {
  animation: slide-out-wipe 0.65s cubic-bezier(0.87, 0, 0.13, 1) forwards;
  will-change: transform;
}

/* ─── Lenis Scroll Smoother ─── */
html.lenis,
html.lenis body {
  height: auto;
}

.lenis.lenis-smooth {
  scroll-behavior: auto !important;
}

.lenis.lenis-smooth [data-lenis-prevent] {
  overscroll-behavior: contain;
}

.lenis.lenis-stopped {
  overflow: hidden;
}

.lenis.lenis-smooth iframe {
  pointer-events: none;
}

/* ─── Custom Brand Scrollbar ─── */
::-webkit-scrollbar {
  width: 12px;
  height: 12px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: #0f7c85;
  /* brand teal */
  border: 3px solid transparent;
  background-clip: padding-box;
  /* keeps padding transparent around thumb */
  border-radius: 9999px;
  transition: background 0.3s ease;
}

::-webkit-scrollbar-thumb:hover {
  background: #3aadaf;
  /* lighter hover teal */
}

/* Firefox compatibility */
* {
  scrollbar-width: thin;
  scrollbar-color: #0f7c85 transparent;
}

/* ─── Swiper Equal Height Cards ─── */
.timeline-swiper .swiper-wrapper {
  display: flex !important;
  align-items: stretch !important;
}

.timeline-swiper .swiper-slide {
  height: auto !important;
  align-self: stretch !important;
  display: flex !important;
}

canvas {
  display: block;
}
