  lists        SubscriberListMember[]
  
  @@unique([siteId, email])
  @@index([siteId])
}

model SubscriberList {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
