                              <tr key={log.id} className="hover:bg-gray-50/50">
                                <td className="px-4 py-3">
                                  {log.success ? (
                                    <span className="inline-flex items-center rounded-full bg-green-50 px-2 py-0.5 text-[9px] font-bold text-green-700 border border-green-200">
                                      Success
