  const updatePhone = (i, field, val) =>
    setPhones((p) =>
      p.map((item, idx) => (idx === i ? { ...item, [field]: val } : item)),
    );

  const addEmail = () => setEmails((e) => [...e, { address: "", label: "" }]);
