              </>
            ) : (
              <>
                <Save size={12} /> {isEditMode ? "Save" : "Publish"}
              </>
            )}
          </button>
        </div>
      </form>

      {/* Media Picker Modal */}
      {showMediaPicker && (
        <MediaPickerModal
          title={
            mediaPickerTarget === "ogImage"
              ? "Select OG Image"
              : "Select Featured Image"
          }
          filter="images"
          onSelect={handleSelectMedia}
          onClose={() => setShowMediaPicker(false)}
          siteId={siteId}
        />
      )}
    </div>
  );
}
</file>

