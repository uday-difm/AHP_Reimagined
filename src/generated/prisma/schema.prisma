generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  SUPERADMIN
  ADMIN
  EDITOR
  AUTHOR
  MARKETING
  VIEWER
  VISITOR
}

enum SiteRole {
  ADMIN
  EDITOR
  AUTHOR
  MARKETING
  VIEWER
  VISITOR
}

model Site {
  id        String    @id @default(cuid())
  name      String
  domain    String?   @unique @db.VarChar(191)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users SiteUser[]
  pages Page[]

  integrationKey       String?                 @unique @db.VarChar(191)
  frontendProjects     FrontendProject[]
  integrationManifests IntegrationManifest[]
  globalSettings       GlobalSettings[]
  webhookEvents        WebhookEvent[]
  webhookSubscriptions WebhookSubscription[]
  posts                Post[]
  categories           Category[]
  tags                 Tag[]
  services             Service[]
  testimonials         Testimonial[]
  faqs                 Faq[]
  teamMembers          TeamMember[]
  legalPages           LegalPage[]
  redirects            Redirect[]
  visitorLogs          VisitorLog[]
  contactSubmissions   ContactFormSubmission[]
  leads                Lead[]
  apiKeys              ApiKey[]
  media                Media[]
  mediaFolders         MediaFolder[]
  ipBlocks             IpBlock[]
  errorLogs            SystemErrorLog[]
  notificationAlerts   NotificationAlert[]
  contentVersions      ContentVersion[]
  newsletters          Newsletter[]
  subscribers          Subscriber[]
  subscriberLists      SubscriberList[]
  emailTemplates       EmailTemplate[]
  emailCampaigns       EmailCampaign[]
  pushNotifications    PushNotification[]
  cookieConsentLogs    CookieConsentLog[]
  comments             Comment[]
  adZones              AdZone[]
  advertisers          Advertiser[]
  adCampaigns          AdCampaign[]
  recipes              Recipe[]

  @@index([isActive])
}

model User {
  id String @id @default(cuid())

  email                String                @unique @db.VarChar(191)
  name                 String?
  bio                  String?
  passwordHash         String
  webhookSubscriptions WebhookSubscription[]
  globalRole           GlobalRole            @default(VIEWER)

  isActive Boolean @default(true)

  twoFAEnabled Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sites SiteUser[]

  auditLogs      AuditLog[]
  loginHistory   LoginHistory[]
  twoFactor      TwoFactor?
  posts          Post[]
  passwordResets PasswordReset[]

  recipes        Recipe[]        @relation("UserRecipes")
  savedRecipes   SavedRecipe[]
  recipeRatings  RecipeRating[]
  recipeComments RecipeComment[]
  recipeLikes    RecipeLike[]

  @@index([email])
  @@index([isActive])
}

model SiteUser {
  id String @id @default(cuid())

  siteId String @db.VarChar(50)
  userId String @db.VarChar(50)

  role SiteRole @default(EDITOR)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
  @@index([siteId])
  @@index([userId])
}

model AuditLog {
  id String @id @default(cuid())

  siteId String?
  userId String?

  action String

  meta Json?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([siteId])
  @@index([userId])
  @@index([createdAt])
}

model LoginHistory {
  id String @id @default(cuid())

  userId String

  ipAddress String?
  userAgent String?

  success Boolean @default(true)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model TwoFactor {
  id String @id @default(cuid())

  userId String @unique

  secret String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Media {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  fileName     String
  originalName String?

  publicId  String
  url       String
  secureUrl String?

  mimeType  String?
  extension String?

  size Int?

  width  Int?
  height Int?

  altText String?

  isImage    Boolean @default(false)
  isVideo    Boolean @default(false)
  isDocument Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  folderId String?
  folder   MediaFolder? @relation(fields: [folderId], references: [id])
  posts    Post[]
  services Service[]

  @@index([siteId])
}

model MediaFolder {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  name String

  parentId String?
  parent   MediaFolder? @relation("FolderTree", fields: [parentId], references: [id])

  children MediaFolder[] @relation("FolderTree")

  media Media[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([siteId])
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

model Page {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  title  String
  slug   String     @db.VarChar(50)
  status PageStatus @default(DRAFT)

  jsonLd Json?

  seoTitle       String?
  seoDescription String?
  canonicalUrl   String?
  ogImage        String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  publishedAt     DateTime?
  publishedBy     String?
  isDiscovered    Boolean   @default(false)
  isManagedBySync Boolean   @default(true)
  isHardcoded     Boolean   @default(false)
  sourceRoute     String?

  // Sitemap fields
  priority     Float?
  changeFreq   String?
  sections     Section[]
  faqs         Faq[]
  syncedRoutes SyncedRoute[]

  @@unique([siteId, slug])
  @@index([siteId])
}

model Section {
  id String @id @default(cuid())

  pageId String
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  name String?

  type String

  order Int @default(0)

  isVisible Boolean @default(true)
  isDeleted Boolean @default(false)

  content Json

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([pageId])
  @@index([pageId, order])
}

model FrontendProject {
  id               String        @id @default(cuid())
  siteId           String
  site             Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name             String
  framework        String
  apiKey           String        @unique @db.VarChar(191)
  isActive         Boolean       @default(true)
  lastSyncAt       DateTime?
  baseUrl          String?
  sdkVersion       String?
  syncStatus       String?
  lastManifestHash String?
  syncedRoutes     SyncedRoute[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([siteId])
  @@index([siteId, isActive])
}

model SyncedRoute {
  id String @id @default(cuid())

  frontendProjectId String
  frontendProject   FrontendProject @relation(fields: [frontendProjectId], references: [id], onDelete: Cascade)

  route        String   @db.VarChar(50)
  source       String?
  discoveredAt DateTime @default(now())
  pageId       String?
  page         Page?    @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@unique([frontendProjectId, route])
  @@index([frontendProjectId])
  @@index([pageId])
}

model IntegrationManifest {
  id           String   @id @default(cuid())
  siteId       String
  source       String?
  manifestHash String?
  rawJson      Json
  createdAt    DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([createdAt])
}

model GlobalSettings {
  id                String    @id @default(cuid())
  siteId            String    @unique
  site              Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  header            Json?
  footer            Json?
  analytics         Json?
  scripts           Json?
  contactDetails    Json?
  websiteSettings   Json?
  emailSettings     Json?
  securityControls  Json?
  compliance        Json?
  notifications     Json?
  ctaConfig         Json?
  performanceConfig Json?
  devTools          Json?
  deploymentNotes   Json?
  navigation        Json?
  adSettings        Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([siteId])
  @@map("GlobalSettings")
}

model WebhookEvent {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  type      String
  payload   Json
  createdAt DateTime @default(now())

  @@index([siteId])
  @@index([type])
}

model WebhookSubscription {
  id        String    @id @default(cuid())
  siteId    String
  site      Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String
  url       String
  events    Json
  secret    String
  isActive  Boolean   @default(true)
  failCount Int       @default(0)
  lastError String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  user      User?     @relation(fields: [userId], references: [id])
  userId    String?

  @@index([siteId])
}

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

model Category {
  id     String @id @default(cuid()) @db.VarChar(50)
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name   String @db.VarChar(50)
  slug   String @db.VarChar(50)
  posts  Post[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([siteId, name])
  @@unique([siteId, slug])
  @@index([siteId])
}

model Tag {
  id     String @id @default(cuid()) @db.VarChar(50)
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name   String @db.VarChar(50)
  slug   String @db.VarChar(50)
  posts  Post[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([siteId, name])
  @@unique([siteId, slug])
  @@index([siteId])
}

model Post {
  id          String     @id @default(cuid()) @db.VarChar(50)
  siteId      String
  site        Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title       String
  slug        String     @db.VarChar(50)
  content     Json?
  contentJson String?    @db.LongText
  excerpt     String?    @db.Text
  status      PostStatus @default(DRAFT)

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  featuredImageId String?
  featuredImage   Media?  @relation(fields: [featuredImageId], references: [id])

  categories Category[]
  tags       Tag[]
  comments   Comment[]

  seoTitle       String?
  seoDescription String?
  canonicalUrl   String?
  ogImage        String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  publishedAt DateTime?

  @@unique([siteId, slug])
  @@index([siteId])
  @@index([siteId, status])
  @@index([authorId])
  @@index([featuredImageId])
}

enum ServiceStatus {
  DRAFT
  ACTIVE
}

enum ServiceVisibility {
  PUBLIC
  PRIVATE
}

model Service {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  title         String
  description   String?           @db.Text
  price         String?
  ctaButtonText String?
  ctaButtonLink String?
  sortOrder     Int               @default(0)
  status        ServiceStatus     @default(DRAFT)
  visibility    ServiceVisibility @default(PUBLIC)
  slug          String?
  accessToken   String?           @unique
  faqs          Json?
  visible       Boolean           @default(true)

  featuredImageId String?
  featuredImage   Media?  @relation(fields: [featuredImageId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([siteId, slug])
  @@index([siteId])
  @@index([featuredImageId])
  @@index([siteId, status, visible])
}

model Testimonial {
  id          String    @id @default(cuid())
  siteId      String
  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  clientName  String
  clientImage String?
  rating      Int       @default(5)
  content     String    @db.Text
  showHide    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([siteId])
  @@index([siteId, sortOrder])
}

model Faq {
  id           String    @id @default(cuid())
  siteId       String
  site         Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  question     String
  answer       String    @db.Text
  pageId       String?
  page         Page?     @relation(fields: [pageId], references: [id], onDelete: SetNull)
  sortOrder    Int       @default(0)
  showHide     Boolean   @default(true)
  schemaMarkup Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([siteId])
  @@index([siteId, sortOrder])
  @@index([pageId])
}

model TeamMember {
  id          String    @id @default(cuid())
  siteId      String
  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  role        String
  photo       String?
  bio         String?   @db.Text
  socialLinks Json?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([siteId])
  @@index([siteId, sortOrder])
}

model LegalPage {
  id          String    @id @default(cuid())
  siteId      String
  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  type        String    @db.VarChar(50)
  title       String
  content     String    @db.LongText
  contentJson String?   @db.LongText
  published   Boolean   @default(false)
  lastUpdated DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Add soft delete support just in case

  @@unique([siteId, type])
  @@index([siteId])
  @@index([type])
}

model Redirect {
  id        String    @id @default(cuid())
  siteId    String
  site      Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  source    String    @db.VarChar(50)
  target    String
  type      Int       @default(301)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([siteId, source])
  @@index([siteId])
}

model VisitorLog {
  id            String   @id @default(cuid())
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  visitorId     String
  pageViewed    String
  ipAddress     String?
  location      String?
  deviceInfo    String?
  trafficSource String?
  duration      Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([siteId])
  @@index([siteId, createdAt])
}

model ContactFormSubmission {
  id        String    @id @default(cuid())
  siteId    String
  site      Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  message   String    @db.Text
  status    String    @default("new") @db.VarChar(20)
  notes     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([siteId])
  @@index([siteId, status])
}

model Lead {
  id              String    @id @default(cuid())
  siteId          String
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name            String
  email           String
  phone           String?
  serviceInterest String?
  sourcePage      String?
  status          String    @default("new") @db.VarChar(20)
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([siteId])
  @@index([siteId, status])
}

model ApiKey {
  id        String    @id @default(cuid())
  siteId    String
  site      Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String
  key       String    @unique @db.VarChar(191)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([siteId])
}

model IpBlock {
  id        String   @id @default(cuid())
  siteId    String
  ipAddress String   @db.VarChar(50)
  reason    String?
  createdAt DateTime @default(now())
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, ipAddress])
  @@index([siteId])
}

model SystemErrorLog {
  id        String   @id @default(cuid())
  siteId    String?
  message   String   @db.Text
  stack     String?  @db.Text
  context   Json?
  createdAt DateTime @default(now())
  site      Site?    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([createdAt])
}

model NotificationAlert {
  id        String   @id @default(cuid())
  siteId    String
  title     String
  message   String
  type      String // "NEW_LEAD" | "FAILED_FORM" | "BLOG_ALERT"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([createdAt])
}

/// Stores revision snapshots for all content types (pages, posts, services, etc.)
model Newsletter {
  id        String   @id @default(cuid())
  siteId    String
  email     String
  status    String   @default("active")
  createdAt DateTime @default(now())
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("Newsletter")
}

model ContentVersion {
  id         String   @id @default(cuid())
  siteId     String
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  entityType String   @db.VarChar(20) // "PAGE", "POST", "SERVICE", "TESTIMONIAL", "FAQ", "TEAM_MEMBER", "LEGAL_PAGE"
  entityId   String   @db.VarChar(36)
  version    Int
  data       Json // Full snapshot of the entity at this version
  createdBy  String? // userId who made the change
  createdAt  DateTime @default(now())

  @@index([siteId, entityType, entityId])
  @@index([siteId, entityType, entityId, version])
  @@index([createdAt])
}

// ========== CRM & SUBSCRIBERS ==========
model Subscriber {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  email     String   @db.VarChar(50)
  name      String?
  status    String   @default("active") // active, unsubscribed, bounced, spam
  tags      String?  @db.Text // Comma-separated or JSON list of tags
  metadata  String?  @db.Text // JSON metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaignLogs CampaignLog[]
  lists        SubscriberListMember[]

  @@unique([siteId, email])
  @@index([siteId])
}

model SubscriberList {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscribers SubscriberListMember[]
  campaigns   EmailCampaign[]

  @@index([siteId])
}

model SubscriberListMember {
  id           String         @id @default(cuid())
  listId       String         @db.VarChar(50)
  list         SubscriberList @relation(fields: [listId], references: [id], onDelete: Cascade)
  subscriberId String         @db.VarChar(50)
  subscriber   Subscriber     @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())

  @@unique([listId, subscriberId])
  @@index([listId])
  @@index([subscriberId])
}

// ========== NEWSLETTERS & CAMPAIGNS ==========
model EmailTemplate {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  subject     String?
  htmlContent String   @db.LongText
  designJson  String?  @db.LongText // Drag-drop builder state
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([siteId])
}

model EmailCampaign {
  id          String          @id @default(cuid())
  siteId      String
  site        Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  subject     String
  body        String          @db.LongText
  listId      String?
  list        SubscriberList? @relation(fields: [listId], references: [id], onDelete: SetNull)
  status      String          @default("draft") // draft, scheduled, sending, sent, failed
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  logs              CampaignLog[]
  pushNotifications PushNotification[]

  @@index([siteId])
}

model CampaignLog {
  id           String        @id @default(cuid())
  campaignId   String        @db.VarChar(50)
  campaign     EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriberId String        @db.VarChar(50)
  subscriber   Subscriber    @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  status       String        @default("pending") // pending, sent, failed, opened, clicked
  errorMessage String?       @db.Text
  sentAt       DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?

  @@unique([campaignId, subscriberId])
  @@index([campaignId])
  @@index([subscriberId])
}

// ========== PUSH NOTIFICATIONS ==========
model PushNotification {
  id              String         @id @default(cuid())
  siteId          String
  site            Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  emailCampaignId String?
  emailCampaign   EmailCampaign? @relation(fields: [emailCampaignId], references: [id], onDelete: SetNull)
  title           String
  message         String         @db.Text
  url             String?
  iconUrl         String? // Custom notification icon URL
  imageUrl        String? // Large hero image URL
  segment         String         @default("Subscribed Users") // OneSignal segment name
  filters         String?        @db.Text // JSON array of custom audience filters
  status          String         @default("draft") // draft, scheduled, sending, sent, failed
  oneSignalId     String? // OneSignal push UUID
  sentCount       Int            @default(0)
  deliveredCount  Int            @default(0)
  clickedCount    Int            @default(0)
  failedCount     Int            @default(0)
  scheduledAt     DateTime?
  sentAt          DateTime?
  isRecurring     Boolean        @default(false)
  recurringRule   String?        @db.Text // JSON recurrence config
  sendToWebsite   Boolean        @default(true)
  sendToDevice    Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([siteId])
  @@index([status])
  @@index([emailCampaignId])
}

// ========== GDPR & CONSENT ==========
model CookieConsentLog {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  visitorId String
  accepted  Boolean  @default(false)
  analytics Boolean  @default(false)
  marketing Boolean  @default(false)
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([siteId])
}

// ========== COMMENTS ==========
model Comment {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  postId      String   @db.VarChar(50)
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorName  String
  authorEmail String
  content     String   @db.Text
  status      String   @default("pending") // pending, approved, spam, trash
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([postId])
  @@index([siteId])
}

// ========== ADVERTISEMENT MANAGEMENT ==========
model AdZone {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String
  slug      String   @db.VarChar(50)
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ads       Ad[]

  @@unique([siteId, slug])
  @@index([siteId])
}

model Advertiser {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  companyName String
  contactName String?
  email       String?
  phone       String?
  website     String?
  logo        String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ads         Ad[]

  @@index([siteId])
}

model AdCampaign {
  id          String    @id @default(cuid())
  siteId      String
  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  description String?   @db.Text
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  ads         Ad[]

  @@index([siteId])
}

model Ad {
  id           String       @id @default(cuid())
  zoneId       String
  zone         AdZone       @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  advertiserId String?
  advertiser   Advertiser?  @relation(fields: [advertiserId], references: [id], onDelete: SetNull)
  campaignId   String?
  campaign     AdCampaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  name         String
  type         String // "banner" or "adsense"
  code         String?      @db.Text
  imageUrl     String?
  targetUrl    String?
  isActive     Boolean      @default(true)
  status       String       @default("draft") // draft, active, scheduled, expired
  startDate    DateTime?
  endDate      DateTime?
  priority     Int          @default(50)
  targeting    String?      @db.Text // JSON for devices, locations, routes
  scheduling   String?      @db.Text // JSON for time limits, days of week
  impressions  Int          @default(0)
  clicks       Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  analytics    AdAnalytic[]

  @@index([zoneId])
  @@index([advertiserId])
  @@index([campaignId])
}

model AdAnalytic {
  id        String   @id @default(cuid())
  adId      String
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  type      String // "impression" or "click"
  visitorId String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([adId])
}

model QuizType {
  id               Int      @id @default(autoincrement())
  slug             String   @unique @db.VarChar(100)
  title            String   @db.VarChar(200)
  subtitle         String?  @db.VarChar(300)
  description      String   @db.Text
  category         String   @db.VarChar(100) // display label e.g. "Wellness"
  categoryColor    String   @default("#0f7c85") @db.VarChar(20)
  imageUrl         String?  @db.VarChar(500)
  icon             String?  @db.VarChar(10) // emoji
  estimatedMinutes Int      @default(5)
  difficulty       String   @default("Beginner") @db.VarChar(50)
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("quiz_types")
}

model Quiz {
  id            Int     @id @default(autoincrement()) @map("_id")
  category      String? @default("general-wellness") @db.VarChar(100)
  question      String  @db.Text
  options       String  @db.Text
  correctAnswer String  @db.Text
  explanation   String  @db.Text

  @@map("quizzes")
}

model IpQuizAnalytic {
  id      Int    @id @default(autoincrement())
  user_ip String @db.VarChar(50)
  played  Int    @default(0)

  @@map("ip_quiz_analytic")
}

model QuizAnalytics {
  id            Int    @id @default(autoincrement())
  userId        String @db.VarChar(255)
  quizId        Int
  correct       Int
  choose_option String @db.VarChar(255)
  time_taken    String @db.VarChar(255)

  @@map("quiz_analytics")
}

model Magazine {
  id               Int      @id @default(autoincrement()) @map("idMagazines")
  magazineId       String   @map("magazine_id") @db.VarChar(255)
  title            String   @map("magazine_title") @db.VarChar(255)
  description      String   @map("magazine_description") @db.Text
  introduction     String?  @map("magazine_introduction") @db.Text
  backImage        String?  @map("magazine_back_image") @db.VarChar(255)
  spineImage       String?  @map("magazine_spine_image") @db.VarChar(255)
  tags             String   @map("magazine_tags") @db.VarChar(255)
  coverImage       String   @map("magazine_cover_image") @db.VarChar(255)
  link             String   @map("magazine_link") @db.VarChar(255)
  date             DateTime @map("magazine_date") @db.Date
  category         String   @map("magazine_category") @db.VarChar(255)
  magCloudLink     String   @map("MagCloudLink") @db.VarChar(255)
  slug             String   @unique @map("magazine_slug") @db.VarChar(191)
  status           Int      @default(1)
  timestamp        DateTime @default(now()) @map("magazine_timestamp")
  publisherSocials Json?    @map("publisher_socials")

  @@map("magazines")
}

model Auth {
  id           Int       @id @default(autoincrement()) @map("idauth")
  name         String?   @db.VarChar(255)
  username     String?   @unique @db.VarChar(191)
  email        String?   @unique @db.VarChar(191)
  password     String?   @db.VarChar(255)
  role         String?   @default("user") @db.VarChar(50)
  profile      String?   @db.VarChar(255)
  profession   String?   @db.VarChar(255)
  bio          String?   @db.Text
  date         DateTime  @default(now())
  otp          String?   @db.VarChar(50)
  otpCreatedAt DateTime?

  @@map("auth")
}

model LegacyAd {
  id             Int             @id @default(autoincrement())
  title          String          @db.VarChar(255)
  description    String?         @db.Text
  mediaUrl       String          @map("media_url") @db.Text
  mediaType      String          @default("image") @map("media_type") @db.VarChar(20)
  targetUrl      String          @map("target_url") @db.Text
  placement      String          @db.VarChar(50)
  status         String          @default("draft") @db.VarChar(20)
  priority       Int             @default(1)
  startDate      DateTime?       @map("start_date")
  endDate        DateTime?       @map("end_date")
  targetDevice   String?         @map("target_device") @db.VarChar(20)
  targetLocation String?         @map("target_location") @db.VarChar(100)
  createdBy      Int?            @map("created_by")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at")
  events         LegacyAdEvent[]

  @@index([placement, status])
  @@map("ads")
}

model LegacyAdEvent {
  id        Int      @id @default(autoincrement())
  adId      Int      @map("ad_id")
  eventType String   @map("event_type") @db.VarChar(10)
  userIp    String?  @map("user_ip") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  ad        LegacyAd @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId, eventType])
  @@map("ad_events")
}

// --- Community Recipe Models ---

enum RecipeStatus {
  PENDING
  APPROVED
  REJECTED
}

model Recipe {
  id     String  @id @default(cuid())
  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  title       String
  description String? @db.Text
  ingredients Json
  steps       Json
  cookingTime Int?
  calories    Int?
  difficulty  String?
  imageUrl    String? @db.Text

  status RecipeStatus @default(PENDING)

  contributorId String
  contributor   User   @relation("UserRecipes", fields: [contributorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags      RecipeTag[]
  allergens RecipeAllergen[]
  ratings   RecipeRating[]
  comments  RecipeComment[]
  savedBy   SavedRecipe[]
  likes     RecipeLike[]

  protein Float?
  carbs   Float?
  fiber   Float?
  fat     Float?
  sugar   Float?

  @@index([siteId])
  @@index([contributorId])
  @@index([status])
}

model RecipeTag {
  id      String   @id @default(cuid())
  name    String   @unique
  recipes Recipe[]
}

model RecipeAllergen {
  id      String   @id @default(cuid())
  name    String   @unique
  recipes Recipe[]
}

model RecipeRating {
  id        String   @id @default(cuid())
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  createdAt DateTime @default(now())

  @@unique([recipeId, userId])
}

model RecipeLike {
  id        String   @id @default(cuid())
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([recipeId, userId])
}

model RecipeComment {
  id        String   @id @default(cuid())
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model SavedRecipe {
  id        String   @id @default(cuid())
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([recipeId, userId])
}
